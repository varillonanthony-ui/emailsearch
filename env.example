# ─────────────────────────────────────────────────────────────────────────────
#  Configuration Email Search – copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AD App Registration ──────────────────────────────────────────────────
# Trouvez ces valeurs dans : portal.azure.com → Azure Active Directory
#   → Inscriptions d'applications → votre app

# ID de l'application (client)
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Secret client (Certificats & secrets → Nouveau secret)
AZURE_CLIENT_SECRET=your_client_secret_here

# ID du tenant (Annuaire → Vue d'ensemble → ID du tenant)
# Seuls les utilisateurs de CE tenant pourront se connecter
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Streamlit ──────────────────────────────────────────────────────────────────
# URI de redirection après authentification Microsoft
# Doit correspondre EXACTEMENT à ce qui est enregistré dans Azure AD
# (Inscriptions d'applications → Authentification → URI de redirection)
#
# En développement local :
REDIRECT_URI=http://localhost:8501
#
# En production (exemple Streamlit Cloud) :
# REDIRECT_URI=https://your-app.streamlit.app

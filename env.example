# ── Secrets Streamlit (.streamlit/secrets.toml en local, Settings > Secrets sur Streamlit Cloud) ──

# ID de l'application Azure AD (app multi-tenant)
AZURE_CLIENT_ID = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Mot de passe applicatif (barrière d'accès commune)
APP_PASSWORD = "votre-mot-de-passe-secret"

# ──────────────────────────────────────────────────────────────────────────────
# AZURE_TENANT_ID n'est plus nécessaire.
# L'app utilise l'endpoint "organizations" qui accepte tous les tenants M365.
#
# Dans Azure AD, l'app doit être configurée en :
# Authentification → Types de comptes pris en charge →
#   "Comptes dans un annuaire organisationnel (tout Azure AD — multi-tenant)"
# ──────────────────────────────────────────────────────────────────────────────
